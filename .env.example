# --- Flask Core ---
FLASK_CONFIG=dev
SITE_NAME="IMMO CRM"
ADMIN_ROLE_NAME="Administrateur"
SECRET_KEY=your_secret_key_here
PREFERRED_URL_SCHEME=http
SESSION_COOKIE_SECURE=True
MAX_CONTENT_LENGTH=16777216

# --- Database (SQLAlchemy) ---
POSTGRES_DB=venone
POSTGRES_USER=venone
POSTGRES_PASSWORD=password
# SQLALCHEMY_DATABASE_URI=sqlite:///db.sqlite
SQLALCHEMY_DATABASE_URI="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@database:5432/${POSTGRES_DB}"

SQLALCHEMY_TRACK_MODIFICATIONS=False
SQLALCHEMY_RECORD_QUERIES=True
SQLALCHEMY_ECHO=False

# --- Security & CSRF ---
WTF_CSRF_ENABLED=True

# --- Mail Configuration ---
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_SENDER=your_email@gmail.com
MAIL_DEFAULT_SENDER=your_email@gmail.com
MAIL_TIMEOUT=30
MAIL_SUBJECT_PREFIX="[Support]"

# --- Cache & Performance ---
CACHE_TYPE=SimpleCache
CACHE_DEFAULT_TIMEOUT=300
MINIFY_HTML=True

# --- FlatPages ---
FLATPAGES_EXTENSION=.md
FLATPAGES_AUTO_RELOAD=True

# --- File Uploads ---
# UPLOAD_FOLDER_PATH=/path/to/uploads
ALLOWED_EXTENSIONS=png,jpg,jpeg,svg

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Logging ---
LOG_DIR=logs

# --- External Services (CinetPay) ---
CINETPAY_SITE_ID=your_site_id
CINETPAY_API_KEY=your_api_key

# --- External Services (SMS Service) ---
SMS_API_KEY=your_sms_api_key
SMS_BASE_URL=https://api.sms-service.com/v1
SMS_SENDER_ID=VENONE
SMS_API_TOKEN=your_sms_token

# --- External Services (Google OAuth) ---
GOOGLE_CONF_URL=https://accounts.google.com/.well-known/openid-configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_SECRET_KEY=your_google_secret_key

# --- Initial Admin Setup (Seed) ---
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@venone.app
ADMIN_PASSWORD=strongpassword123
ADMIN_PHONE_NUMBER=+221XXXXXXXXX

# --- Application Logic ---
TOKEN_EXPIRATION_DAYS=3
ALLOWED_COUNTRIES=SN,TG,BF,CM,CG,GN,CD,NE,BJ,ML,KM
